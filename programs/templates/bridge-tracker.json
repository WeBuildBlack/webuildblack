        "options": [
          { "name": "Frontend / Full-Stack", "color": "blue" },
          { "name": "Backend / Infra", "color": "green" },
          { "name": "Mobile", "color": "orange" },
          { "name": "Data", "color": "purple" },
          { "name": "Design", "color": "pink" },
          { "name": "Product / PM", "color": "yellow" }
